rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // 2. Categories Rules
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if true; // In full-stack proxy, server handles security
    }

    // 3. Poems Rules
    match /poems/{poemId} {
      allow read: if true;
      allow write: if true;
    }

    // 4. Cloudinary Config Rules
    match /config/cloudinary {
      allow read: if true;
      allow write: if true;
    }
  }
}
