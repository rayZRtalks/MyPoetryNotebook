rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- 1. Global Default-Deny Catch-All ---
    match /{document=**} {
      allow read, write: if false;
    }

    // --- 2. Global Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isAuthor() {
      return isSignedIn() && request.auth.token.email == 'soumyaranjan.ray@gmail.com';
    }

    // --- 3. Standalone Validation Helpers ---
    function isValidCategory(data) {
      return data.id is string 
        && data.name is string 
        && data.color is string;
    }

    function isValidPoem(data) {
      return data.id is string 
        && data.title is string 
        && data.body is string 
        && data.categoryId is string;
    }

    // --- 4. Rules for Categories ---
    match /categories/{categoryId} {
      allow read: if true;
      allow create, update: if isAuthor() && isValidCategory(request.resource.data);
      allow delete: if isAuthor();
    }

    // --- 5. Rules for Poems ---
    match /poems/{poemId} {
      allow read: if resource == null 
                  || resource.data.isPrivate == false 
                  || isAuthor();
      allow create, update: if isAuthor() && isValidPoem(request.resource.data);
      allow delete: if isAuthor();
    }
  }
}
