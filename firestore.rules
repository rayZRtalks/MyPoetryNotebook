rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- 1. Global Default-Deny Catch-All ---
    match /{document=**} {
      allow read, write: if false;
    }

    // --- 2. Rules for Categories ---
    match /categories/{categoryId} {
      allow read, write: if true;
    }

    // --- 3. Rules for Poems ---
    match /poems/{poemId} {
      allow read, write: if true;
    }
  }
}
